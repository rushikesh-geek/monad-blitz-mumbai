# Backend runtime
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
CONTRACT_ADDRESS=0xYourDeployedContract
OPENROUTER_API_KEY=replace_with_openrouter_key
OPERATOR_PRIVATE_KEY=0xreplace_with_operator_private_key
AGENT_1_PRIVATE_KEY=0xreplace_with_agent_1_private_key
AGENT_2_PRIVATE_KEY=0xreplace_with_agent_2_private_key
AGENT_3_PRIVATE_KEY=0xreplace_with_agent_3_private_key
AGENT_4_PRIVATE_KEY=0xreplace_with_agent_4_private_key
BACKEND_URL=https://your-backend.up.railway.app
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app
# Optional for read-only process checks; keep false in production
DISABLE_WORKERS=false

# Optional explicit addresses; otherwise derived from the private keys
OPERATOR_ADDRESS=0xYourOperatorAddress
AGENT_1_ADDRESS=0xYourAgent1Address
AGENT_2_ADDRESS=0xYourAgent2Address
AGENT_3_ADDRESS=0xYourAgent3Address
AGENT_4_ADDRESS=0xYourAgent4Address
